---
import { siteConfig } from "../config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={`Projects by ${siteConfig.name} — ${siteConfig.title}`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@600&display=swap"
      rel="stylesheet"
    />
    <title>Projects — {siteConfig.name}</title>
  </head>
  <body>
    <Header />

    <main class="pt-28 pb-24 px-8 sm:px-12 md:px-16 lg:px-24 max-w-7xl mx-auto">
      <!-- Back link + page heading -->
      <div class="mb-16">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-8 group"
        >
          <svg
            class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 12H5M12 5l-7 7 7 7"
            />
          </svg>
          Back to home
        </a>

        <h1
          class="text-4xl sm:text-5xl md:text-7xl font-bold text-gray-900 mt-6"
        >
          Projects
        </h1>
        <div
          class="w-[75px] h-[5px] mt-3 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        >
        </div>
        <p class="mt-5 text-base sm:text-lg text-gray-500">
          {siteConfig.projects.length} project{siteConfig.projects.length !== 1 ? "s" : ""}
        </p>
      </div>

      <!-- Projects grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {
          siteConfig.projects.map((project, index) => {
            return (
              <div class="group relative flex">
                <a
                  href={`/projects/${project.slug}`}
                  class="flex flex-col w-full bg-white rounded-2xl border border-gray-200 overflow-hidden transition-all duration-300 hover:shadow-xl hover:border-gray-300 hover:-translate-y-1"
                >
                  <!-- Image carousel -->
                  {project.images && project.images.length > 0 ? (
                    <div class="relative aspect-video overflow-hidden bg-gray-100" data-image-carousel>
                      <div
                        class="flex h-full transition-transform duration-700 ease-in-out"
                        data-image-track
                      >
                        {project.images.map((img, imgIndex) => (
                          <img
                            src={img}
                            alt={`${project.name} — screenshot ${imgIndex + 1}`}
                            class="w-full h-full object-cover flex-shrink-0"
                            loading="lazy"
                          />
                        ))}
                      </div>
                      {project.link && (
                        <div class="absolute top-3 right-3 w-9 h-9 flex items-center justify-center bg-gray-900/75 backdrop-blur-sm rounded-full text-white transition-all duration-300 group-hover:bg-gray-900 z-10">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                          </svg>
                        </div>
                      )}
                      {project.images.length > 1 && (
                        <div
                          class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-1.5 z-10"
                          data-image-dots
                        >
                          {project.images.map((_, imgIndex) => (
                            <button
                              class="h-1.5 rounded-full transition-all duration-300 focus:outline-none"
                              data-img-index={imgIndex}
                              aria-label={`Image ${imgIndex + 1}`}
                              style={imgIndex === 0
                                ? "width:16px;background-color:rgba(255,255,255,0.95)"
                                : "width:6px;background-color:rgba(255,255,255,0.45)"}
                            />
                          ))}
                        </div>
                      )}
                    </div>
                  ) : (
                    <div
                      class="aspect-video flex items-center justify-center text-white/30 text-5xl font-bold"
                      style={`background: linear-gradient(135deg, ${siteConfig.accentColor}33 0%, ${siteConfig.accentColor}11 100%)`}
                    >
                      {String(index + 1).padStart(2, "0")}
                    </div>
                  )}

                  <div class="flex flex-col gap-4 flex-1 p-6">
                    <div>
                      <span
                        class="text-sm font-mono"
                        style={{ color: siteConfig.accentColor }}
                      >
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <h2 class="text-xl font-bold text-gray-900 mt-1">
                        {project.name}
                      </h2>
                    </div>

                    <p class="text-base text-gray-600 leading-relaxed flex-1">
                      {project.description}
                    </p>

                    {project.skills && project.skills.length > 0 && (
                      <div class="flex flex-wrap gap-2 pt-2 mt-auto">
                        {project.skills.map((skill) => (
                          <span
                            class={`px-3 py-1.5 bg-gray-900 text-white rounded-lg text-sm font-medium transition-all duration-300 ${
                              project.link ? "group-hover:bg-gray-800" : ""
                            }`}
                          >
                            {skill}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </div>
            );
          })
        }
      </div>
    </main>

    <Footer />
  </body>

  <script>
    // Auto-rotating inner image carousels
    document.querySelectorAll("[data-image-carousel]").forEach((carousel) => {
      const track = carousel.querySelector("[data-image-track]");
      const dotsContainer = carousel.querySelector("[data-image-dots]");
      const dots = dotsContainer
        ? Array.from(dotsContainer.querySelectorAll("button"))
        : [];
      let imgCurrent = 0;
      const imgTotal = dots.length || 1;

      function goToImage(index) {
        imgCurrent = ((index % imgTotal) + imgTotal) % imgTotal;
        track.style.transform = `translateX(-${imgCurrent * 100}%)`;
        dots.forEach((dot, i) => {
          dot.style.width = i === imgCurrent ? "16px" : "6px";
          dot.style.backgroundColor =
            i === imgCurrent
              ? "rgba(255,255,255,0.95)"
              : "rgba(255,255,255,0.45)";
        });
      }

      dots.forEach((dot, i) => {
        dot.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          goToImage(i);
        });
      });

      if (imgTotal > 1) {
        setInterval(() => goToImage(imgCurrent + 1), 3000);
      }
    });
  </script>
</html>
