---
import { siteConfig } from "../../config";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/global.css";

export function getStaticPaths() {
  return siteConfig.projects.map((project, index) => ({
    params: { slug: project.slug },
    props: {
      project,
      index,
      prev: index > 0 ? siteConfig.projects[index - 1] : null,
      next:
        index < siteConfig.projects.length - 1
          ? siteConfig.projects[index + 1]
          : null,
    },
  }));
}

const { project, index, prev, next } = Astro.props;
const accent = siteConfig.accentColor;
const padded = String(index + 1).padStart(2, "0");
const totalImages = project.images?.length ?? 0;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={project.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@600&display=swap"
      rel="stylesheet"
    />
    <title>{project.name} — {siteConfig.name}</title>
  </head>

  <body class="bg-white min-h-screen">
    <Header />

    <!-- Breadcrumb / action bar -->
    <div
      class="sticky top-0 z-40 bg-white/90 backdrop-blur-sm border-b border-gray-100"
    >
      <div
        class="max-w-6xl mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4"
      >
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors group flex-shrink-0"
        >
          <svg
            class="w-4 h-4 transition-transform group-hover:-translate-x-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 12H5M12 5l-7 7 7 7"></path>
          </svg>
          All Projects
        </a>

        <span class="text-sm text-gray-400 hidden sm:block truncate text-center"
          >{project.name}</span
        >

        {
          project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm px-4 py-1.5 rounded-lg text-white transition-all hover:opacity-90 flex-shrink-0"
              style={`background-color: ${accent}`}
            >
              Visit Live
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 17L17 7M17 7H7M17 7V17"
                />
              </svg>
            </a>
          )
        }
      </div>
    </div>

    <!-- Hero image carousel -->
    {
      project.images && project.images.length > 0 && (
        <div
          class="w-full bg-gray-100 overflow-hidden relative"
          data-hero-carousel
        >
          <div class="aspect-video md:aspect-[21/9] relative overflow-hidden">
            <!-- Track -->
            <div
              class="flex h-full transition-transform duration-700 ease-in-out"
              data-hero-track
            >
              {project.images.map((img, i) => (
                <img
                  src={img}
                  alt={`${project.name} — screenshot ${i + 1}`}
                  class="w-full h-full object-cover flex-shrink-0"
                  loading={i === 0 ? "eager" : "lazy"}
                />
              ))}
            </div>

            <!-- Gradient overlay (bottom) -->
            <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/30 to-transparent pointer-events-none" />

            <!-- Prev arrow -->
            {project.images.length > 1 && (
              <button
                data-hero-prev
                class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-black/40 hover:bg-black/65 backdrop-blur-sm rounded-full text-white transition-all z-10 focus:outline-none"
                aria-label="Previous image"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 19l-7-7 7-7"
                  />
                </svg>
              </button>
            )}

            <!-- Next arrow -->
            {project.images.length > 1 && (
              <button
                data-hero-next
                class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-black/40 hover:bg-black/65 backdrop-blur-sm rounded-full text-white transition-all z-10 focus:outline-none"
                aria-label="Next image"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </button>
            )}

            <!-- Dot indicators -->
            {project.images.length > 1 && (
              <div
                class="absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-2 z-10"
                data-hero-dots
              >
                {project.images.map((_, i) => (
                  <button
                    class="h-1.5 rounded-full transition-all duration-300 focus:outline-none"
                    aria-label={`Image ${i + 1}`}
                    style={
                      i === 0
                        ? "width:20px;background-color:rgba(255,255,255,0.95)"
                        : "width:6px;background-color:rgba(255,255,255,0.4)"
                    }
                  />
                ))}
              </div>
            )}

            <!-- Image counter -->
            {project.images.length > 1 && (
              <span class="absolute bottom-4 right-5 text-xs text-white/70 z-10 tabular-nums" data-hero-counter>
                1 / {project.images.length}
              </span>
            )}
          </div>
        </div>
      )
    }

    <!-- Main content -->
    <main class="max-w-6xl mx-auto px-6 sm:px-10 py-14">
      <!-- Project header -->
      <div class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span
            class="text-sm font-mono tracking-wider"
            style={`color: ${accent}`}>{padded}</span
          >
          {
            project.status && (
              <span class="text-xs px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200">
                {project.status}
              </span>
            )
          }
          {
            project.year && (
              <span class="text-sm text-gray-400">{project.year}</span>
            )
          }
        </div>

        <h1
          class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 leading-[1.1] mb-5"
        >
          {project.name}
        </h1>

        {
          project.role && (
            <p class="text-base text-gray-500 tracking-wide">{project.role}</p>
          )
        }
      </div>

      <!-- Divider -->
      <div
        class="h-px w-full mb-12"
        style={`background: linear-gradient(to right, ${accent}66, transparent)`}
      >
      </div>

      <!-- Two-column body -->
      <div class="grid lg:grid-cols-3 gap-12 lg:gap-16 items-start">
        <!-- Left: 2/3 -->
        <div class="lg:col-span-2 space-y-10">
          <!-- Short description -->
          <p class="text-xl text-gray-600 leading-relaxed">
            {project.description}
          </p>

          <!-- Long description -->
          {
            project.longDescription && (
              <p class="text-base text-gray-500 leading-[1.85]">
                {project.longDescription}
              </p>
            )
          }

          <!-- Feature highlights -->
          {
            project.features && project.features.length > 0 && (
              <div>
                <h3 class="text-[11px] uppercase tracking-[0.18em] text-gray-400 mb-7">
                  Highlights
                </h3>
                <ul class="space-y-5">
                  {project.features.map((feature) => (
                    <li class="flex items-start gap-4">
                      <span
                        class="w-5 h-5 flex-shrink-0 mt-0.5 flex items-center justify-center rounded-full text-white text-[10px]"
                        style={`background-color: ${accent}`}
                      >
                        ✓
                      </span>
                      <span class="text-gray-700 leading-snug">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>

        <!-- Right: 1/3 sticky card -->
        <div class="lg:col-span-1">
          <div
            class="sticky top-20 rounded-2xl border border-gray-200 overflow-hidden divide-y divide-gray-100"
          >
            <!-- Meta -->
            {
              (project.year || project.role || project.status) && (
                <div class="p-6 space-y-5">
                  {project.year && (
                    <div>
                      <span class="text-[10px] uppercase tracking-widest text-gray-400 block mb-1.5">
                        Year
                      </span>
                      <span class="text-sm text-gray-900">{project.year}</span>
                    </div>
                  )}
                  {project.role && (
                    <div>
                      <span class="text-[10px] uppercase tracking-widest text-gray-400 block mb-1.5">
                        Role
                      </span>
                      <span class="text-sm text-gray-900">{project.role}</span>
                    </div>
                  )}
                  {project.status && (
                    <div>
                      <span class="text-[10px] uppercase tracking-widest text-gray-400 block mb-1.5">
                        Status
                      </span>
                      <span class="text-xs px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200">
                        {project.status}
                      </span>
                    </div>
                  )}
                </div>
              )
            }

            <!-- Tech stack -->
            {
              project.skills && project.skills.length > 0 && (
                <div class="p-6">
                  <span class="text-[10px] uppercase tracking-widest text-gray-400 block mb-4">
                    Tech Stack
                  </span>
                  <div class="flex flex-wrap gap-2">
                    {project.skills.map((skill) => (
                      <span class="px-3 py-1.5 bg-gray-900 text-white text-xs rounded-lg">
                        {skill}
                      </span>
                    ))}
                  </div>
                </div>
              )
            }

            <!-- CTA button -->
            {
              project.link && (
                <div class="p-6">
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-xl text-white text-sm font-semibold transition-all hover:opacity-90 active:scale-[0.98]"
                    style={`background-color: ${accent}`}
                  >
                    Visit Project
                    <svg
                      class="w-3.5 h-3.5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M7 17L17 7M17 7H7M17 7V17"
                      />
                    </svg>
                  </a>
                </div>
              )
            }
          </div>
        </div>
      </div>

      <!-- Prev / Next project navigation -->
      <div class="mt-20 pt-10 border-t border-gray-100 grid grid-cols-2 gap-4">
        {
          prev ? (
            <a
              href={`/projects/${prev.slug}`}
              class="group flex flex-col gap-2 p-5 rounded-2xl border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all duration-200"
            >
              <span class="text-xs text-gray-400 flex items-center gap-1.5">
                <svg
                  class="w-3.5 h-3.5 transition-transform group-hover:-translate-x-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 12H5M12 5l-7 7 7 7"
                  />
                </svg>
                Previous
              </span>
              <span class="text-sm text-gray-900 font-semibold leading-snug line-clamp-2">
                {prev.name}
              </span>
            </a>
          ) : (
            <div />
          )
        }

        {
          next ? (
            <a
              href={`/projects/${next.slug}`}
              class="group flex flex-col gap-2 p-5 rounded-2xl border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all duration-200 text-right ml-auto w-full"
            >
              <span class="text-xs text-gray-400 flex items-center gap-1.5 justify-end">
                Next
                <svg
                  class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 12h14M12 5l7 7-7 7"
                  />
                </svg>
              </span>
              <span class="text-sm text-gray-900 font-semibold leading-snug line-clamp-2">
                {next.name}
              </span>
            </a>
          ) : (
            <div />
          )
        }
      </div>
    </main>

    <Footer />

    <script>
      // Hero carousel with arrows, dots, counter, auto-advance, and keyboard
      const heroCarousel = document.querySelector("[data-hero-carousel]");
      if (heroCarousel) {
        const track = heroCarousel.querySelector(
          "[data-hero-track]"
        ) as HTMLElement;
        const prevBtn = heroCarousel.querySelector("[data-hero-prev]");
        const nextBtn = heroCarousel.querySelector("[data-hero-next]");
        const dotsContainer = heroCarousel.querySelector("[data-hero-dots]");
        const counter = heroCarousel.querySelector("[data-hero-counter]");
        const dots = dotsContainer
          ? Array.from(dotsContainer.querySelectorAll("button"))
          : [];
        const total = dots.length || 1;
        let current = 0;
        let timer: ReturnType<typeof setInterval> | null = null;

        function goTo(index: number) {
          current = ((index % total) + total) % total;
          track.style.transform = `translateX(-${current * 100}%)`;
          dots.forEach((dot, i) => {
            (dot as HTMLElement).style.width = i === current ? "20px" : "6px";
            (dot as HTMLElement).style.backgroundColor =
              i === current
                ? "rgba(255,255,255,0.95)"
                : "rgba(255,255,255,0.4)";
          });
          if (counter) counter.textContent = `${current + 1} / ${total}`;
        }

        function startAuto() {
          if (total <= 1) return;
          timer = setInterval(() => goTo(current + 1), 4000);
        }

        function stopAuto() {
          if (timer) clearInterval(timer);
        }

        prevBtn?.addEventListener("click", () => {
          stopAuto();
          goTo(current - 1);
          startAuto();
        });

        nextBtn?.addEventListener("click", () => {
          stopAuto();
          goTo(current + 1);
          startAuto();
        });

        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => {
            stopAuto();
            goTo(i);
            startAuto();
          });
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "ArrowRight") { stopAuto(); goTo(current + 1); startAuto(); }
          if (e.key === "ArrowLeft")  { stopAuto(); goTo(current - 1); startAuto(); }
        });

        // Touch / swipe
        let touchStartX = 0;
        heroCarousel.addEventListener("touchstart", (e) => {
          touchStartX = (e as TouchEvent).touches[0].clientX;
        }, { passive: true });
        heroCarousel.addEventListener("touchend", (e) => {
          const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
          if (Math.abs(diff) > 40) {
            stopAuto();
            goTo(current + (diff > 0 ? 1 : -1));
            startAuto();
          }
        }, { passive: true });

        startAuto();
      }
    </script>
  </body>
</html>
